          </StackPanel>
        </Border>
      </Grid>
      <Grid Name="DownloadIsoPanel" Grid.Column="1" Visibility="Collapsed">
        <Border Background="{DynamicResource PanelAltBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="16" VerticalAlignment="Top">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
