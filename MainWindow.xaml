              <Grid Grid.Row="4" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TabControl Grid.Column="0" Background="Transparent" BorderThickness="0">
                  <TabItem Name="AnalyzeBigFilesTab" Header="Largest files">
                    <DataGrid Name="BigFilesGrid" Margin="0,8,0,0" Background="#F8FAFC" Foreground="#0F172A" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" CanUserSortColumns="True" GridLinesVisibility="Horizontal" RowHeight="24" SelectionChanged="AnalyzeGrid_SelectionChanged" MouseDoubleClick="AnalyzeRow_DoubleClick">
                      <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Del" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="44" />
                        <DataGridTextColumn Header="File name" Binding="{Binding Name}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Folder" Binding="{Binding Folder}" Width="3*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Modified" Binding="{Binding DateText}" SortMemberPath="Modified" Width="130" IsReadOnly="True" />
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" SortMemberPath="Size" Width="100" IsReadOnly="True" />
                      </DataGrid.Columns>
                    </DataGrid>
                  </TabItem>
                  <TabItem Name="AnalyzeDupesTab" Header="Duplicate files">
                    <DataGrid Name="DupesGrid" Margin="0,8,0,0" Background="#F8FAFC" Foreground="#0F172A" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserSortColumns="True" CanUserAddRows="False" GridLinesVisibility="Horizontal" RowHeight="24" SelectionChanged="AnalyzeGrid_SelectionChanged" MouseDoubleClick="AnalyzeRow_DoubleClick">
                      <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding Keep}" Value="True">
                              <Setter Property="Background" Value="#DCFCE7" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Selected}" Value="True">
                              <Setter Property="Background" Value="#FEE2E2" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsReference}" Value="True">
                              <Setter Property="Background" Value="#DBEAFE" />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </DataGrid.RowStyle>
                      <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="Del" Binding="{Binding Selected, UpdateSourceTrigger=PropertyChanged}" Width="44">
                          <DataGridCheckBoxColumn.ElementStyle>
                            <Style TargetType="CheckBox">
                              <Setter Property="HorizontalAlignment" Value="Center" />
                              <Setter Property="IsEnabled" Value="{Binding CanDelete}" />
                            </Style>
                          </DataGridCheckBoxColumn.ElementStyle>
                          <DataGridCheckBoxColumn.EditingElementStyle>
                            <Style TargetType="CheckBox">
                              <Setter Property="HorizontalAlignment" Value="Center" />
                              <Setter Property="IsEnabled" Value="{Binding CanDelete}" />
                            </Style>
                          </DataGridCheckBoxColumn.EditingElementStyle>
                        </DataGridCheckBoxColumn>
                        <DataGridTextColumn Header="Group" Binding="{Binding Group}" SortMemberPath="Group" Width="60" IsReadOnly="True" />
                        <DataGridTextColumn Header="File name" Binding="{Binding Name}" Width="2*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Folder" Binding="{Binding Folder}" Width="3*" IsReadOnly="True" />
                        <DataGridTextColumn Header="Modified" Binding="{Binding DateText}" SortMemberPath="Modified" Width="130" IsReadOnly="True" />
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" SortMemberPath="Size" Width="100" IsReadOnly="True" />
                      </DataGrid.Columns>
                    </DataGrid>
                  </TabItem>
                </TabControl>
                <Border Grid.Column="1" Width="250" Margin="10,8,0,0" Background="#0B1220" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" CornerRadius="6">
                  <Grid Margin="6">
                    <Grid.RowDefinitions>
                      <RowDefinition Height="*" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Name="AnalyzePreviewHint" Grid.Row="0" Text="Select a file to preview" Foreground="{DynamicResource MutedBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="6" />
                    <Image Name="AnalyzePreviewImage" Grid.Row="0" Stretch="Uniform" />
                    <TextBlock Name="AnalyzePreviewInfo" Grid.Row="1" Text="" Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="2,8,2,2" />
                  </Grid>
                </Border>
              </Grid>
              <StackPanel Grid.Row="5" Margin="0,10,0,0">
                <Border Name="AnalyzeUndoBar" Visibility="Collapsed" Background="#1E293B" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,0,8" HorizontalAlignment="Left">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Name="AnalyzeUndoText" Text="" Foreground="{DynamicResource TextBrush}" FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Name="AnalyzeUndoButton" Content="Undo" Height="26" Padding="14,0" Style="{StaticResource GreenButtonStyle}" Click="AnalyzeUndo_Click" />
                    <Button Name="AnalyzeUndoDismissButton" Content="✕" Height="26" Width="28" Margin="6,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="AnalyzeUndoDismiss_Click" />
                  </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                  <Border Width="13" Height="13" Background="#22C55E" CornerRadius="3" VerticalAlignment="Center" />
                  <TextBlock Name="AnLegendKeep" Text="kept" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="6,0,18,0" VerticalAlignment="Center" />
                  <Border Width="13" Height="13" Background="#EF4444" CornerRadius="3" VerticalAlignment="Center" />
                  <TextBlock Name="AnLegendDel" Text="will be moved to the Recycle Bin (you can restore it)" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                <Button Name="AnalyzeSmartCleanButton" Content="Smart clean" Height="30" Margin="0,0,8,0" Style="{StaticResource GreenButtonStyle}" Click="AnalyzeSmartClean_Click" />
                <Button Name="AnalyzeKeepFirstButton" Content="Select duplicates (keep 1)" Height="30" Style="{StaticResource GhostButtonStyle}" Click="AnalyzeKeepFirst_Click" />
                <Button Name="AnalyzeGalleryButton" Content="Gallery" Height="30" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="AnalyzeGallery_Click" />
                <Button Name="AnalyzeSimilarButton" Content="Similar photos" Height="30" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="AnalyzeSimilar_Click" />
                <Button Name="AnalyzeOpenFolderButton" Content="Open folder" Height="30" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="AnalyzeOpenFolder_Click" />
                <Button Name="AnalyzeDeleteButton" Content="Delete selected" Height="30" Margin="8,0,0,0" Style="{StaticResource OrangeButtonStyle}" Click="AnalyzeDelete_Click" />
                <TextBlock Name="AnalyzeStatusText" Text="" Foreground="{DynamicResource MutedBrush}" FontSize="13" VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </TabItem>
          </TabControl>
        </Border>
      </Grid>
    </Grid>
    <Border Grid.Row="2" Background="#070B12" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="0,1,0,0">
      <Grid Margin="24,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="112" />
          <ColumnDefinition Width="112" />
          <ColumnDefinition Width="180" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Name="StatusText" Text="Ready." FontSize="14" />
          <TextBlock Name="StartHintText" Text="" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource OrangeBrush}" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,2,0,0" />
          <TextBlock Name="ProgressStatsText" Text="Progress: 0.0% | Elapsed: 00:00:00 | Remaining: --:--:--" FontSize="13" Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0" />
          <Grid Margin="0,8,24,0">
            <ProgressBar Name="ProgressBar" Height="22" Minimum="0" Maximum="100" />
            <TextBlock Name="ProgressPercentText" Text="0%" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
          </Grid>
        </StackPanel>
        <Button Name="PauseButton" Grid.Column="1" Content="Pause" Height="44" Margin="0,0,8,0" VerticalAlignment="Center" IsEnabled="False" Style="{StaticResource OrangeButtonStyle}" Click="PauseButton_Click" />
        <Button Name="StopButton" Grid.Column="2" Content="Stop" Height="44" Margin="0,0,8,0" VerticalAlignment="Center" IsEnabled="False" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Foreground="White" Click="StopButton_Click" />
        <Button Name="StartButton" Grid.Column="3" Content="Create USB" Height="44" VerticalAlignment="Center" Style="{StaticResource GreenButtonStyle}" Click="StartButton_Click" />
      </Grid>
    </Border>
    <Border Name="SettingsOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#CC020617" Visibility="Collapsed" Panel.ZIndex="50">
      <Border Width="520" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="12" Padding="0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource BlueBrush}" CornerRadius="12,12,0,0" Padding="18,14">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Foreground="White" />
                <TextBlock Name="SettingsTitleText" Text="Settings" FontSize="18" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" />
              </StackPanel>
              <Button Grid.Column="1" Content="&#xE711;" FontFamily="Segoe MDL2 Assets" Width="34" Height="30" Background="#33FFFFFF" BorderBrush="#33FFFFFF" Click="SettingsClose_Click" />
            </Grid>
          </Border>
          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
            <StackPanel>
              <Expander Name="AccentColorExpander" Header="Accent color" IsExpanded="False" Foreground="{DynamicResource TextBrush}" FontSize="15" FontWeight="SemiBold">
                <WrapPanel Name="AccentPresetsPanel" Margin="0,10,0,0" />
              </Expander>
              <TextBlock Name="SettingsAppearanceLabel" Text="Appearance" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,8" />
              <WrapPanel Margin="0,0,0,4">
                <Button Name="ThemeDarkButton" Content="Dark" Tag="dark" Width="118" Margin="0,0,8,8" Click="Theme_Click" Style="{StaticResource GhostButtonStyle}" />
                <Button Name="ThemeLightButton" Content="Light" Tag="light" Width="118" Margin="0,0,8,8" Click="Theme_Click" Style="{StaticResource GhostButtonStyle}" />
                <Button Name="ThemeSystemButton" Content="System" Tag="system" Width="118" Margin="0,0,8,8" Click="Theme_Click" Style="{StaticResource GhostButtonStyle}" />
              </WrapPanel>
              <TextBlock Name="SettingsThemeLabel" Text="Base theme (dark accents)" FontSize="15" FontWeight="SemiBold" Margin="0,18,0,8" />
              <WrapPanel>
                <Button Content="Midnight" Tag="0F172A" Width="120" Margin="0,0,8,8" Click="BaseTheme_Click" Style="{StaticResource GhostButtonStyle}" />
                <Button Content="Carbon" Tag="0A0A0F" Width="120" Margin="0,0,8,8" Click="BaseTheme_Click" Style="{StaticResource GhostButtonStyle}" />
                <Button Content="Slate" Tag="1A2233" Width="120" Margin="0,0,8,8" Click="BaseTheme_Click" Style="{StaticResource GhostButtonStyle}" />
                <Button Content="Deep Plum" Tag="1A1024" Width="120" Margin="0,0,8,8" Click="BaseTheme_Click" Style="{StaticResource GhostButtonStyle}" />
              </WrapPanel>
              <Expander Name="CustomAccentExpander" Header="Custom accent" IsExpanded="False" Foreground="{DynamicResource TextBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,18,0,0">
                <Grid Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Border Grid.Column="0" Width="64" Height="64" CornerRadius="8" Margin="0,0,14,0">
                    <Border.Background>
                      <SolidColorBrush x:Name="CustomPreviewBrush" Color="#2563EB" />
                    </Border.Background>
                  </Border>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <Grid Margin="0,0,0,4">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="22"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="R" VerticalAlignment="Center" Foreground="#F87171" FontWeight="SemiBold" />
                      <Slider Grid.Column="1" Name="RedSlider" Minimum="0" Maximum="255" Value="37" ValueChanged="ColorSlider_Changed" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="22"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="G" VerticalAlignment="Center" Foreground="#4ADE80" FontWeight="SemiBold" />
                      <Slider Grid.Column="1" Name="GreenSlider" Minimum="0" Maximum="255" Value="99" ValueChanged="ColorSlider_Changed" />
                    </Grid>
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="22"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="B" VerticalAlignment="Center" Foreground="#60A5FA" FontWeight="SemiBold" />
                      <Slider Grid.Column="1" Name="BlueSlider" Minimum="0" Maximum="255" Value="235" ValueChanged="ColorSlider_Changed" />
                    </Grid>
                    <Button Name="ApplyCustomButton" Content="Apply custom accent" Margin="0,12,0,0" HorizontalAlignment="Left" FontWeight="SemiBold" Click="ApplyCustomAccent_Click" />
                  </StackPanel>
                </Grid>
              </Expander>

              <Expander Name="BehaviorExpander" Header="Behavior" IsExpanded="False" Foreground="{DynamicResource TextBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,0">
                <StackPanel Margin="0,10,0,0">
                  <CheckBox Name="SoundOnFinishCheck" Content="Play a sound when an operation finishes" IsChecked="True" FontWeight="Normal" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                  <CheckBox Name="FlashOnFinishCheck" Content="Flash the taskbar when finished (if window is in background)" IsChecked="True" FontWeight="Normal" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4" />
                  <CheckBox Name="RememberTaskCheck" Content="Remember the last used task on startup" FontWeight="Normal" Foreground="{DynamicResource TextBrush}" />
                </StackPanel>
              </Expander>

              <Expander Name="LogsExpander" Header="Files &amp; logs" IsExpanded="False" Foreground="{DynamicResource TextBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,0">
                <WrapPanel Margin="0,10,0,0">
                  <Button Name="OpenLogsFolderButton" Content="Open logs folder" Margin="0,0,8,8" FontWeight="SemiBold" Style="{StaticResource GhostButtonStyle}" Click="OpenLogsFolder_Click" />
                  <Button Name="OpenLastReportSettingsButton" Content="Open last report" Margin="0,0,8,8" FontWeight="SemiBold" Style="{StaticResource GhostButtonStyle}" Click="OpenReportButton_Click" />
                </WrapPanel>
              </Expander>

              <Border Height="1" Background="{DynamicResource Border2Brush}" Margin="0,16,0,0" />
              <TextBlock Name="SettingsAboutLabel" Text="About &amp; support" FontSize="15" FontWeight="SemiBold" Margin="0,14,0,8" />
              <TextBlock Name="AboutVersionText" Text="DriveForge 4.1.0" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" />
              <TextBlock Name="AboutPrivacyText" Text="Free and portable. No ads, no telemetry, no data collection — your files never leave your PC." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0" />
              <TextBlock Name="AboutEngineText" Text="Clone/backup engine: wimlib 1.14.4 (GPLv3), bundled inside the app." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0" />
              <TextBlock Name="SettingsSupportText" Text="DriveForge is free. If it helped you, you can support its development — thank you!" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,14,0,8" />
              <Button Name="DonateButton" Content="☕  Support on Ko-fi" HorizontalAlignment="Left" Style="{StaticResource OrangeButtonStyle}" Click="OpenDonate_Click" ToolTip="Opens the DriveForge Ko-fi page in your browser (pay by card, Apple/Google Pay or PayPal — no account needed). The app never asks for or handles payment details itself." />
              <CheckBox Name="ShowDonatePromptCheck" Content="Show a support message after a successful operation" IsChecked="True" Foreground="{DynamicResource MutedBrush}" Margin="0,10,0,0" />
            </StackPanel>
          </ScrollViewer>
          <Border Grid.Row="2" Background="{DynamicResource BoxBrush}" CornerRadius="0,0,12,12" Padding="18,12">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Button Grid.Column="0" Name="ResetThemeButton" Content="Reset to default" HorizontalAlignment="Left" Style="{StaticResource GhostButtonStyle}" Click="ResetTheme_Click" />
              <Button Grid.Column="1" Name="SettingsDoneButton" Content="Done" Width="100" Style="{StaticResource GreenButtonStyle}" Click="SettingsClose_Click" />
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Border>
  </Grid>
</Window>
