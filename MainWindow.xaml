<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="WinUsbMaker.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="DriveForge" Height="720" Width="1100" MinHeight="620" MinWidth="820" WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="{DynamicResource NavyBrush}" xmlns:winusbmaker="clr-namespace:WinUsbMaker;assembly=WinUsbMaker" Loaded="Window_Loaded" Closing="Window_Closing" AllowDrop="True" DragOver="Window_DragOver" Drop="Window_Drop">
  <Window.TaskbarItemInfo>
    <TaskbarItemInfo x:Name="TaskbarInfo" />
  </Window.TaskbarItemInfo>
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <SolidColorBrush x:Key="NavyBrush" Color="#0F172A" />
      <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
      <SolidColorBrush x:Key="PanelAltBrush" Color="#172033" />
      <SolidColorBrush x:Key="BlueBrush" Color="#2563EB" />
      <SolidColorBrush x:Key="GreenBrush" Color="#16A34A" />
      <SolidColorBrush x:Key="OrangeBrush" Color="#F59E0B" />
      <SolidColorBrush x:Key="RedBrush" Color="#DC2626" />
      <SolidColorBrush x:Key="TextBrush" Color="#F8FAFC" />
      <SolidColorBrush x:Key="MutedBrush" Color="#CBD5E1" />
      <SolidColorBrush x:Key="BoxBrush" Color="#0B1220" />
      <SolidColorBrush x:Key="DividerBrush" Color="#1E3A5F" />
      <SolidColorBrush x:Key="Border2Brush" Color="#334155" />
      <Style x:Key="{x:Type TextBlock}" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
      </Style>
      <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="#F8FAFC" />
        <Setter Property="Background" Value="{DynamicResource BlueBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinHeight" Value="32" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border x:Name="Bd" CornerRadius="7" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Opacity" Value="0.86" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Opacity" Value="0.70" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                  <Setter Property="FrameworkElement.Cursor" Value="Arrow" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="GhostButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
      </Style>
      <Style x:Key="{x:Type ProgressBar}" TargetType="{x:Type ProgressBar}">
        <Setter Property="Foreground" Value="{DynamicResource BlueBrush}" />
        <Setter Property="Background" Value="{DynamicResource BoxBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type ProgressBar}">
              <Border CornerRadius="6" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" ClipToBounds="True">
                <Grid>
                  <Border x:Name="PART_Track" />
                  <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="6" Background="{TemplateBinding Foreground}" />
                </Grid>
              </Border>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="GreenButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource GreenBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GreenBrush}" />
      </Style>
      <Style x:Key="OrangeButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource OrangeBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OrangeBrush}" />
        <Setter Property="Foreground" Value="#111827" />
      </Style>
      <Style x:Key="{x:Type TextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="#0F172A" />
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="FontSize" Value="13" />
      </Style>
      <Style x:Key="{x:Type ComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="#0F172A" />
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="BorderBrush" Value="{DynamicResource BlueBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="7,3" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="ItemTemplate">
          <Setter.Value>
            <DataTemplate>
              <TextBlock Foreground="#0F172A" TextWrapping="NoWrap" Text="{Binding}" />
            </DataTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type ComboBoxItem}" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="#0F172A" />
        <Setter Property="Background" Value="#F8FAFC" />
        <Setter Property="Padding" Value="9,7" />
        <Style.Triggers>
          <Trigger Property="ComboBoxItem.IsHighlighted" Value="True">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#BFDBFE" />
          </Trigger>
          <Trigger Property="ListBoxItem.IsSelected" Value="True">
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="#DBEAFE" />
          </Trigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="62" />
      <RowDefinition Height="*" />
      <RowDefinition Height="78" />
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="{DynamicResource NavyBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="0,0,0,1">
      <Grid Margin="24,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Name="AppTitleText" Text="DriveForge" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Name="AppSubtitleText" Text="Create Windows USB drives, clone this PC, and check drive quality" FontSize="12" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}" Margin="0,0,6,0" />
          <ComboBox Name="LanguageBox" Width="140" Height="30" VerticalAlignment="Center" SelectionChanged="LanguageBox_SelectionChanged" />
          <Button Name="HelpButton" Content="&#xE897;" FontFamily="Segoe MDL2 Assets" Width="40" Height="30" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="HelpButton_Click" ToolTip="How to use DriveForge" />
          <Button Name="SettingsButton" Content="&#xE713;" FontFamily="Segoe MDL2 Assets" Width="40" Height="30" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="SettingsButton_Click" ToolTip="Settings" />
          <Border VerticalAlignment="Center" Margin="10,0,0,0" CornerRadius="7" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" Padding="14,8">
            <StackPanel Orientation="Horizontal">
              <Ellipse Name="AdminDot" Width="12" Height="12" Fill="{StaticResource OrangeBrush}" VerticalAlignment="Center" />
              <TextBlock Name="AdminStatusText" Text="Checking administrator mode" Margin="10,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>
    <Grid Grid.Row="1" Margin="10,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="246" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Border Grid.Column="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,6,0" Padding="8">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
          <TextBlock Name="SbTasks" Text="TASKS" Foreground="{DynamicResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="6,0,0,4" />
          <Button Name="NavCreate" Tag="0" Click="NavTask_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE88E;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbCreateT" Text="Create Windows USB" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbCreateS" Text="Install Windows from an ISO file" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavClonePortable" Tag="2" Click="NavTask_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbClonePT" Text="Clone to USB / external drive" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbClonePS" Text="Portable Windows that boots on any PC" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavCloneInternal" Tag="3" Click="NavTask_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE977;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbCloneIT" Text="Clone to internal disk" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbCloneIS" Text="Normal Windows install on another disk" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavBackup" Tag="4" Click="NavTask_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbBackupT" Text="Back up to image" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbBackupS" Text="Save this PC to a .wim image file" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavRestore" Tag="1" Click="NavTask_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbRestoreT" Text="Restore image" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbRestoreS" Text="Write a saved image back to a drive" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavLinux" Tag="5" Click="NavTask_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbLinuxT" Text="Bootable USB from ISO" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbLinuxS" Text="Linux or any ISO — written as a disk image" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavDownloadIso" Click="NavDownloadIso_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbDownloadT" Text="Download an ISO" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbDownloadS" Text="Get Windows or Linux install images" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavMultiBoot" Click="NavMultiBoot_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbMultiBootT" Text="Multi-boot USB" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbMultiBootS" Text="Many ISOs on one stick — pick at boot" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Border Height="1" Background="{DynamicResource DividerBrush}" Margin="6,4" />
          <TextBlock Name="SbTools" Text="TOOLS" Foreground="{DynamicResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="6,0,0,4" />
          <Button Name="NavTools" Click="NavTools_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbToolsT" Text="Drive tools" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbToolsS" Text="Health, speed and file-system scan" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavRecover" Click="NavRecover_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbRecoverT" Text="Recover deleted files" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbRecoverS" Text="Undelete files from a drive (NTFS)" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
          <Button Name="NavClean" Click="NavClean_Click" Style="{StaticResource GhostButtonStyle}" HorizontalContentAlignment="Stretch" Padding="10,4" Margin="0,0,0,2">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
              <TextBlock Text="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="17" VerticalAlignment="Center" />
              <StackPanel Grid.Column="1">
                <TextBlock Name="SbCleanT" Text="Clean traces" FontWeight="SemiBold" FontSize="13" />
                <TextBlock Name="SbCleanS" Text="Free space &amp; wipe usage traces" FontSize="11" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Button>
        </StackPanel>
        </ScrollViewer>
      </Border>
      <ScrollViewer Name="LeftPanelScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <Border Visibility="Collapsed" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="8">
          <StackPanel>
            <ComboBox Name="ModeBox" Height="30" SelectionChanged="ModeBox_SelectionChanged" />
            <Button Name="CreateKitButton" Content="Prepare current computer clone" Margin="0,5,0,0" Style="{StaticResource OrangeButtonStyle}" Click="CreateKitButton_Click" />
          </StackPanel>
        </Border>
        <Border Name="TaskHeaderBorder" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
          <StackPanel>
            <TextBlock Name="TaskTitleText" Text="Create Windows USB" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Name="SourceHelpTextTop" Text="" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,0" />
          </StackPanel>
        </Border>
        <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,6,0,0">
          <StackPanel>
            <TextBlock Name="Step2Title" Text="2. Windows source" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Name="SourceHelpText" Text="ISO / WIM / ESD or current Windows." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,4" />
            <Grid Name="SourceFileRow">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="88" />
              </Grid.ColumnDefinitions>
              <TextBox Name="SourcePathBox" IsReadOnly="True" Height="30" />
              <Button Name="BrowseButton" Grid.Column="1" Content="Browse" Margin="8,0,0,0" Click="BrowseSource_Click" />
            </Grid>
            <TextBlock Name="EditionLabel" Text="Windows edition" Margin="0,4,0,2" FontWeight="SemiBold" />
            <ComboBox Name="EditionBox" Height="30" />
            <Button Name="VerifyIsoButton" Content="Verify ISO checksum" Margin="0,6,0,0" HorizontalAlignment="Left" Width="170" Style="{StaticResource GhostButtonStyle}" Click="VerifyIsoButton_Click" ToolTip="Compute the SHA-256 of the selected ISO so you can compare it with the value on the official download page — confirms the file is genuine and not corrupted." />
          </StackPanel>
        </Border>
        <Border Name="TargetSection" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,6,0,0">
          <StackPanel>
            <TextBlock Name="Step3Title" Text="3. Target USB / SSD / HDD" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Name="Step3Desc" Text="Selected disk will be formatted." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,4" />
            <ComboBox Name="DiskBox" Height="30" SelectionChanged="DiskBox_SelectionChanged" ToolTip="Pick the USB stick / SSD / HDD to write to. Everything on it will be erased. Your system disk is hidden so it cannot be picked by mistake." />
            <Border Name="DriveVerdictBorder" CornerRadius="6" Padding="8,5" Margin="0,6,0,0" Visibility="Collapsed">
              <TextBlock Name="DriveVerdictText" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="White" />
            </Border>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
              <Button Name="RefreshDisksButton" Content="Refresh disks" Width="112" Click="RefreshDisks_Click" />
              <Button Name="CheckDriveButton" Content="Check drive" Width="104" Margin="8,0,0,0" Click="SpeedTest_Click" />
              <Button Name="EjectDriveButton" Content="Safely remove" Width="116" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="EjectDrive_Click" ToolTip="Flush and eject the selected drive so you can unplug it safely (for USB / external drives)." />
            </StackPanel>
          </StackPanel>
        </Border>
        <Border Name="OptionsSection" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,6,0,0">
          <StackPanel>
            <TextBlock Name="Step4Title" Text="4. Options" FontSize="16" FontWeight="SemiBold" />
            <TextBlock Name="BootModeText" Text="Boot mode: Automatic." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,2,0,4" />
            <CheckBox Name="BypassRequirementsCheck" Content="Bypass Windows 11 system requirements" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3" ToolTip="Lets Windows 11 install on PCs without TPM 2.0 / Secure Boot / new CPU. Only matters for a fresh ISO install — check it if your PC is &quot;not supported&quot;." />
            <CheckBox Name="BypassAccountCheck" Content="Bypass Microsoft account requirements" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3" ToolTip="Skip the Microsoft-account requirement on first boot. You will be asked to choose a local account name and password during creation." />
            <CheckBox Name="DebloatCheck" Content="Remove bloatware (Copilot, Teams, ads, telemetry)" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3" ToolTip="Writes Microsoft's own group-policy settings into the new Windows to turn off Copilot, the Teams/Chat icon, suggested apps and ads, web search in Start, the advertising ID, and to set telemetry to the minimum. Applied offline to the install image — reversible, installs nothing extra." />
            <CheckBox Name="AddNetworkDriversCheck" Content="Add this PC's network / Wi-Fi drivers" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3" ToolTip="Copies this computer's network and Wi-Fi drivers into the new Windows so Wi-Fi appears during first-time setup. Most useful when you will install on the same or a similar PC." />
            <CheckBox Name="AddAllDriversCheck" Content="Add ALL of this PC's drivers (slower)" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3" ToolTip="Copies every third-party driver from this PC into the new Windows (graphics, chipset, audio, network…). Best when installing on the same hardware. Takes longer and uses more space." />
            <CheckBox Name="BitLockerCheck" Content="Enable BitLocker and save recovery key" Foreground="{DynamicResource TextBrush}" ToolTip="Encrypt the new drive so the data is protected if it is lost or stolen. You choose a password; a recovery key is also saved to a file you pick." />
            <CheckBox Name="BitLockerResumeCheck" Content="Let me remove the drive before encryption finishes (resumes after first boot)" IsChecked="True" Foreground="{DynamicResource MutedBrush}" Margin="18,2,0,0" ToolTip="Encryption can take a while. With this on you can unplug as soon as the clone is done — Windows finishes encrypting automatically the first time the clone boots." />
            <CheckBox Name="DataPartitionCheck" Content="Create a data partition with the leftover space" Foreground="{DynamicResource TextBrush}" Margin="0,3,0,0" ToolTip="Cap Windows at a sensible size and turn the remaining free space into a second, empty drive (e.g. for your files)." />
            <CheckBox Name="CloneOtherPartitionsCheck" Content="Also clone the other data partitions from this PC's disk" Foreground="{DynamicResource TextBrush}" Margin="0,3,0,0" ToolTip="If this PC's disk has other data partitions (e.g. a D: drive), copy them onto the target too, each into its own partition." />
            <CheckBox Name="VerifyContentCheck" Content="Verify cloned data after writing (slower, safer)" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,3,0,0" ToolTip="After cloning, re-read every file from the drive and compare it to the original to catch a bad USB stick. Adds time; uncheck only if you trust the drive." />
            <CheckBox Name="CompactImageCheck" Content="Compact image (smaller on disk, slightly slower at runtime)" IsChecked="True" Foreground="{DynamicResource TextBrush}" Margin="0,3,0,0" ToolTip="Store Windows compressed so it takes less space on the drive. Saves space; apps open a hair slower. Good for smaller USB drives." />
            <CheckBox Name="EjectWhenDoneCheck" Content="Eject the drive when finished" Foreground="{DynamicResource TextBrush}" Margin="0,3,0,0" ToolTip="When the operation completes, safely flush and eject the drive so you can unplug it right away. Skipped if BitLocker is still encrypting." />
          </StackPanel>
        </Border>
        <Button Name="ScheduleCloneButton" Content="Schedule this clone (automatic backup)…" Margin="0,6,0,0" HorizontalAlignment="Left" Visibility="Collapsed" Style="{StaticResource GhostButtonStyle}" Click="ScheduleCloneButton_Click" ToolTip="Create a Windows scheduled task that re-runs this clone automatically (daily or weekly) to the selected drive — an automatic backup. Keep the drive connected at that time." />
        <Border Name="Step5Section" Visibility="Collapsed" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,6,0,0">
          <StackPanel>
            <TextBlock Name="Step5Title" Text="5. HDD / USB tools" FontSize="16" FontWeight="SemiBold" />
