          </StackPanel>
        </Border>
      </StackPanel>
      </ScrollViewer>
      <Grid Name="DiagnosticPanel" Grid.Column="1" Visibility="Collapsed">
        <Border Background="{DynamicResource PanelAltBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="210" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource BoxBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="7" Padding="8" Margin="0,0,10,0" VerticalAlignment="Top">
              <StackPanel>
                <TextBlock Name="ToolGrpDiagnose" Text="Diagnostics" Foreground="{DynamicResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="2,0,0,5" />
                <Button Name="HealthToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="SelectHealthTool_Click" ToolTip="Read SMART / reliability health with a Good / Caution / Bad verdict and a temperature trend.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE95E;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbHealth" Text="Health" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Name="SpeedToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="SelectSpeedTool_Click" ToolTip="Measure sequential and random write speed and rate the drive.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE916;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbSpeed" Text="Speed" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Name="ScanToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="SelectScanTool_Click" ToolTip="Check the file system for errors with CHKDSK /scan (read-only).">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8FE;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbScan" Text="Scan" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Name="SurfaceToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="SurfaceTest_Click" ToolTip="Read every sector to find bad / unreadable blocks (read-only surface test).">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbSurface" Text="Surface" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Name="CapacityToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="CapacityTest_Click" ToolTip="Verify the drive's REAL capacity (detects fake/counterfeit USB drives). Tests the free space.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbCapacity" Text="Capacity" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <TextBlock Name="ToolGrpMaintain" Text="Maintenance" Foreground="{DynamicResource MutedBrush}" FontSize="11" FontWeight="SemiBold" Margin="2,10,0,5" />
                <Button Name="FormatToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="FormatDrive_Click" ToolTip="Quick-format the selected drive (erases everything). Choose NTFS, exFAT or FAT32. Your system disk is protected.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbFormat" Text="Format" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Name="PartitionToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="PartitionTool_Click" ToolTip="Partition tools: resize, move, create, delete, quick-partition, initialize, convert MBR/GPT, check, set active, find lost. Your system disk is protected.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbPartition" Text="Partition" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Name="TestBootToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Style="{StaticResource GhostButtonStyle}" Click="TestBoot_Click" ToolTip="Boot the drive in a temporary Hyper-V VM to verify it actually starts, without rebooting your PC. Requires Hyper-V.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbTestBoot" Text="Test boot" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <TextBlock Name="ToolGrpErase" Text="Erase" Foreground="#F0A8A8" FontSize="11" FontWeight="SemiBold" Margin="2,10,0,5" />
                <Button Name="WipeToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Click="WipeDrive_Click" ToolTip="Securely erase the whole drive (overwrite) or the free space, or SSD TRIM-erase. Your system disk is protected.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xEA99;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbWipe" Text="Wipe" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
                <Button Name="ShredToolButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Margin="0,0,0,4" Padding="9,7" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Click="ShredFiles_Click" ToolTip="Securely erase specific files or a whole folder (overwrite then delete). Does not touch the rest of the drive.">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White" VerticalAlignment="Center" Margin="0,0,9,0" /><TextBlock Name="TbShred" Text="Shred" Foreground="White" VerticalAlignment="Center" /></StackPanel>
                </Button>
              </StackPanel>
            </Border>
            <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource BoxBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="7" Padding="10">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Name="DiagTitle" Text="Drive Diagnostic Center" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                  <TextBlock Name="ToolStatusText" Text="Pick the drive to test, then choose a tool (health, speed, SMART, scan, repair)." TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" Margin="0,3,0,0" />
                  <TextBlock Name="DiagDriveToTestLabel" Text="Drive to test" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,8,0,3" />
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Name="DiagDiskBox" Height="30" SelectionChanged="DiagDiskBox_SelectionChanged" ToolTip="Choose which disk to run the diagnostic on (includes your system disk — diagnostics never format or write to it)." />
                    <Button Name="DiagRefreshButton" Grid.Column="1" Content="Refresh" Width="84" Margin="8,0,0,0" Style="{StaticResource GhostButtonStyle}" Click="RefreshDisks_Click" />
                  </Grid>
                </StackPanel>
                <!-- tool buttons moved to the left rail -->
              </Grid>
            </Border>
            <!-- Disk/Speed/Result summary cards hidden: info now lives in the Overview tab (kept in tree so UpdateDiskSummary still runs) -->
            <Grid Grid.Row="1" Margin="0" Visibility="Collapsed">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Background="{DynamicResource NavyBrush}" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" Padding="7" Margin="0,0,6,0">
                <StackPanel>
                  <TextBlock Name="DiagDiskCardLabel" Text="Disk" Foreground="{DynamicResource MutedBrush}" />
                  <TextBlock Name="DiskSummaryText" Text="No disk selected" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
              </Border>
              <Border Grid.Column="1" Background="{DynamicResource NavyBrush}" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" Padding="7" Margin="0,0,6,0">
                <StackPanel>
                  <TextBlock Name="DiagSpeedCardLabel" Text="Speed" Foreground="{DynamicResource MutedBrush}" />
                  <TextBlock Name="SpeedSummaryText" Text="Not tested" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
              </Border>
              <Border Grid.Column="2" Background="{DynamicResource NavyBrush}" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" Padding="7">
                <StackPanel>
                  <TextBlock Name="DiagResultCardLabel" Text="Result" Foreground="{DynamicResource MutedBrush}" />
                  <TextBlock Name="RecommendationText" Text="Select a disk" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,2,0,0" />
                </StackPanel>
              </Border>
            </Grid>
            <Border Name="WarningBox" Grid.Row="2" Visibility="Collapsed" Background="#2A1B08" BorderBrush="{StaticResource OrangeBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,8,0,0">
              <TextBlock Name="WarningText" Text="Windows To Go needs fast random I/O. Slow USB sticks may feel broken." TextWrapping="Wrap" Foreground="#FDE68A" />
            </Border>
            <Border Grid.Row="3" Background="{DynamicResource NavyBrush}" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,8,0,0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TabControl Name="DriveToolsTabs" Grid.Row="0" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BlueBrush}" Foreground="{DynamicResource TextBrush}">
                  <TabControl.ItemContainerStyle>
                    <Style TargetType="{x:Type TabItem}">
                      <Setter Property="Height" Value="0" />
                      <Setter Property="Padding" Value="0" />
                      <Setter Property="Margin" Value="0" />
                      <Setter Property="BorderThickness" Value="0" />
                    </Style>
                  </TabControl.ItemContainerStyle>
                  <TabItem Name="TabOverview" Header="Overview">
                    <Grid Background="{DynamicResource NavyBrush}" Margin="6">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <!-- LEFT: drive info (scrolls if it gets tall) -->
                      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,12,0">
                        <StackPanel>
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Name="HealthStatusCard" Background="#475569" CornerRadius="6" Padding="8" Margin="0,0,4,0">
                              <StackPanel>
                                <TextBlock Name="LblHealthStatus" Text="Health Status" FontSize="12" Foreground="White" />
                                <TextBlock Name="ToolHealthText" Text="Unknown" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{DynamicResource BlueBrush}" CornerRadius="6" Padding="8" Margin="4,0,0,0">
                              <StackPanel>
                                <TextBlock Name="LblTemperature" Text="Temperature" FontSize="12" />
                                <TextBlock Name="ToolTemperatureText" Text="-- °C" FontSize="20" FontWeight="Bold" />
                              </StackPanel>
                            </Border>
                          </Grid>
                          <TextBlock Name="ToolDriveTitleText" Text="No drive selected" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,10,0,0" />
                          <TextBlock Name="ToolFirmwareText" Text="Firmware: unknown" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" />
                          <TextBlock Name="ToolSerialText" Text="Serial: unknown" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" />
                          <TextBlock Name="ToolInterfaceText" Text="Interface: unknown" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" />
                          <TextBlock Name="ToolSizeText" Text="Size: unknown" Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" />
                          <TextBlock Name="ToolRecommendationDetailText" Text="Run a health or speed test to get a recommendation." Margin="0,8,0,0" TextWrapping="Wrap" />
                          <TextBlock Name="HealthTrendText" Text="" Margin="0,8,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                          <Border Name="HealthTrendBox" Visibility="Collapsed" Margin="0,10,0,0" Background="{DynamicResource BoxBrush}" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" CornerRadius="6" Padding="8">
                            <StackPanel>
                              <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <TextBlock Name="HealthTrendGraphLabel" Text="Temperature trend" Foreground="{DynamicResource MutedBrush}" FontSize="12" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Name="HealthTrendRangeText" Text="" Foreground="{DynamicResource MutedBrush}" FontSize="11" />
                              </Grid>
                              <Canvas Name="HealthTrendCanvas" Height="66" Margin="0,6,0,0" ClipToBounds="True" SizeChanged="HealthTrendCanvas_SizeChanged" />
                            </StackPanel>
                          </Border>
                          <TextBlock x:Name="PartitionMapLabel" Text="Partition map" Foreground="{DynamicResource MutedBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,12,0,6" />
                          <Grid Name="PartitionMapGrid" Height="34" Margin="0,0,0,4" />
                        </StackPanel>
                      </ScrollViewer>
                      <!-- RIGHT: SMART / drive details table, fills full height so it never clips -->
                      <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                          <RowDefinition Height="Auto" />
                          <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="DriveDetailsLabel" Text="Drive details" Foreground="{DynamicResource MutedBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <DataGrid Grid.Row="1" Name="SmartGrid"
                                  Background="#0E1830" Foreground="{DynamicResource TextBrush}"
                                  RowBackground="#0E1830" AlternatingRowBackground="#0C1526" AlternationCount="2"
                                  BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#1B2A45"
                                  RowHeaderWidth="0" VerticalScrollBarVisibility="Auto"
                                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False">
                          <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="{x:Type DataGridColumnHeader}">
                              <Setter Property="Background" Value="#13213A" />
                              <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                              <Setter Property="FontWeight" Value="SemiBold" />
                              <Setter Property="Padding" Value="8,6" />
                              <Setter Property="BorderBrush" Value="#1B2A45" />
                              <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                          </DataGrid.ColumnHeaderStyle>
                          <DataGrid.CellStyle>
                            <Style TargetType="{x:Type DataGridCell}">
                              <Setter Property="Background" Value="Transparent" />
                              <Setter Property="BorderThickness" Value="0" />
                              <Setter Property="Padding" Value="8,5" />
                              <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                              <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                  <Setter Property="Background" Value="{DynamicResource BlueBrush}" />
                                  <Setter Property="Foreground" Value="White" />
                                </Trigger>
                              </Style.Triggers>
                            </Style>
                          </DataGrid.CellStyle>
                          <DataGrid.Columns>
                            <DataGridTextColumn Header="Attribute" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100">
                              <DataGridTextColumn.ElementStyle>
                                <Style TargetType="{x:Type TextBlock}">
                                  <Setter Property="FontWeight" Value="SemiBold" />
                                  <Setter Property="Padding" Value="6,0,0,0" />
                                  <Setter Property="VerticalAlignment" Value="Center" />
                                  <Setter Property="Foreground" Value="#94A3B8" />
                                  <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusKind}" Value="good"><Setter Property="Foreground" Value="#22C55E" /></DataTrigger>
                                    <DataTrigger Binding="{Binding StatusKind}" Value="warn"><Setter Property="Foreground" Value="#F59E0B" /></DataTrigger>
                                    <DataTrigger Binding="{Binding StatusKind}" Value="bad"><Setter Property="Foreground" Value="#EF4444" /></DataTrigger>
                                  </Style.Triggers>
                                </Style>
                              </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                          </DataGrid.Columns>
                        </DataGrid>
                      </Grid>
                    </Grid>
                  </TabItem>
                  <TabItem Name="TabSpeed" Header="Speed">
                    <StackPanel Background="{DynamicResource NavyBrush}" Margin="8">
                      <TextBlock Name="LblBenchmark" Text="Benchmark result" FontSize="15" FontWeight="SemiBold" />
                      <TextBlock Name="SpeedVisualText" Text="No speed test completed yet." Margin="0,6,0,8" TextWrapping="Wrap" />
                      <Grid Margin="0,0,0,10">
                        <ProgressBar Name="LiveTestBar" Height="24" Minimum="0" Maximum="100" Value="0" />
                        <TextBlock Name="LiveTestPercentText" Text="Idle" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" Foreground="White" />
                      </Grid>
                      <TextBlock Name="LblSeqWrite" Text="Sequential write" Foreground="{DynamicResource MutedBrush}" />
                      <ProgressBar Name="SequentialSpeedBar" Height="14" Minimum="0" Maximum="150" Value="0" Margin="0,3,0,8" />
                      <TextBlock Name="LblRandWrite" Text="Random 4K write" Foreground="{DynamicResource MutedBrush}" />
                      <ProgressBar Name="RandomSpeedBar" Height="14" Minimum="0" Maximum="20" Value="0" Margin="0,3,0,8" />
                      <TextBlock Name="SpeedAdviceText" Text="Run Speed test for a Good / Usable / Not recommended rating." TextWrapping="Wrap" />
                    </StackPanel>
                  </TabItem>
                  <TabItem Name="TabScan" Header="Scan">
                    <StackPanel Background="{DynamicResource NavyBrush}" Margin="8">
                      <TextBlock Name="LblFsScan" Text="File-system scan" FontSize="15" FontWeight="SemiBold" />
                      <TextBlock Name="LblScanDesc" Text="Checks the selected drive letter with CHKDSK /scan. It looks for file-system and volume errors. It does not format, clone, erase, or run a full physical bad-sector test." Margin="0,6,0,8" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" />
                      <Border Background="{DynamicResource BoxBrush}" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" CornerRadius="5" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                          <TextBlock Name="LblWhenUse" Text="When to use it" FontWeight="SemiBold" />
                          <TextBlock Name="LblScanWhenDesc" Text="Use Scan for a quick, safe read-only check of the file system. It never writes to or formats the drive." Margin="0,4,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" />
                        </StackPanel>
                      </Border>
                      <TextBlock Name="ScanStatusText" Text="No scan has been run yet." Margin="0,0,0,8" TextWrapping="Wrap" />
                      <ProgressBar Name="ScanProgressBar" Height="14" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,8" />
                      <TextBlock Name="ScanAdviceText" Text="Scan checks logical file-system problems. For a deep physical surface test, a dedicated third-party surface-scan tool can be used." TextWrapping="Wrap" />
                    </StackPanel>
                  </TabItem>
                  <TabItem Name="TabDetails" Header="Details">
                    <TextBox Name="ToolOutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Background="#F8FAFC" Foreground="#0F172A" />
                  </TabItem>
                </TabControl>
              </Grid>
            </Border>
            <Border Grid.Row="4" Background="{DynamicResource BoxBrush}" BorderBrush="{DynamicResource Border2Brush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,8,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="98" />
                  <ColumnDefinition Width="98" />
                  <ColumnDefinition Width="98" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Name="LblDiagControls" Text="Diagnostic controls" FontWeight="SemiBold" />
                  <TextBlock Name="LblDiagControlsDesc" Text="Choose a diagnostic tool above, then use Start, Pause, or Stop for that test." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,2,8,0" />
                </StackPanel>
                <Button Name="ToolStartButton" Grid.Column="1" Content="Start" Height="34" Margin="0,0,6,0" Style="{StaticResource GreenButtonStyle}" Click="ToolStartButton_Click" />
                <Button Name="ToolPauseButton" Grid.Column="2" Content="Pause" Height="34" Margin="0,0,6,0" IsEnabled="False" Style="{StaticResource OrangeButtonStyle}" Click="ToolPauseButton_Click" />
                <Button Name="ToolStopButton" Grid.Column="3" Content="Stop" Height="34" IsEnabled="False" Background="{StaticResource RedBrush}" BorderBrush="{StaticResource RedBrush}" Foreground="White" Click="ToolStopButton_Click" />
              </Grid>
            </Border>
            <Expander Grid.Row="5" Name="ExpShowLogs" Header="Show logs" IsExpanded="False" Foreground="{DynamicResource TextBrush}" Margin="0,8,0,0">
              <StackPanel>
                <Button Name="OpenReportButton" Content="Open last report" HorizontalAlignment="Left" Height="30" Margin="0,6,0,0" IsEnabled="False" Style="{StaticResource GhostButtonStyle}" Click="OpenReportButton_Click" />
                <TextBox Name="LogBox" Margin="0,6,0,0" Height="150" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Background="#F8FAFC" Foreground="#0F172A" />
              </StackPanel>
            </Expander>
            </Grid>
          </Grid>
        </Border>
      </Grid>
      <Grid Name="MultiBootPanel" Grid.Column="1" Visibility="Collapsed">
        <Border Background="{DynamicResource PanelAltBrush}" BorderBrush="{DynamicResource BlueBrush}" BorderThickness="1" CornerRadius="8" Padding="16" VerticalAlignment="Top">
